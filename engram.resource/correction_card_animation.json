{
  "meta": {
    "name": "Correction Card Animation",
    "version": "1.0.0",
    "description": "Three-state correction card animation: Accept → Undo → Ignore",
    "frameRate": 60,
    "totalDuration": 8500,
    "loop": true
  },
  "design": {
    "card": {
      "width": 492,
      "borderRadius": 8,
      "border": "1px solid #E5E5E5",
      "background": "#FFFFFF",
      "padding": 20,
      "fontFamily": "Pretendard"
    },
    "typography": {
      "sentence": { "fontSize": 16, "lineHeight": 24, "color": "#1A1A1A" },
      "deleted": { "fontSize": 16, "lineHeight": 24, "color": "#C13F3F", "textDecoration": "line-through" },
      "inserted": { "fontSize": 16, "lineHeight": 24, "color": "#FF8C50" },
      "statusText": { "fontSize": 14, "lineHeight": 14, "color": "#FF8C50" },
      "ignoredText": { "fontSize": 16, "lineHeight": 16, "color": "#888888" },
      "buttonLabel": { "fontSize": 14, "lineHeight": 14 }
    },
    "buttons": {
      "width": 96,
      "height": 36,
      "borderRadius": 6,
      "iconSize": 24,
      "default": {
        "background": "#FFFFFF",
        "border": "1px solid #D0D0D0",
        "color": "#888888"
      },
      "accept": {
        "background": "#FF8C50",
        "border": "none",
        "color": "#FFFFFF"
      }
    },
    "colors": {
      "accent": "#FF8C50",
      "deleted": "#C13F3F",
      "muted": "#888888",
      "border": "#E5E5E5",
      "buttonBorder": "#D0D0D0",
      "iconFill": "#555555"
    }
  },
  "cards": {
    "card01": {
      "height": 112,
      "layout": "column",
      "justifyContent": "space-between",
      "rows": [
        {
          "type": "text",
          "segments": [
            { "text": "Greaphing designing", "style": "deleted" },
            { "text": "Graphic design", "style": "inserted" },
            { "text": " is a strong suit of mine.", "style": "sentence" }
          ]
        },
        {
          "type": "actions",
          "left": [
            { "id": "bookmark-icon", "icon": "bookmark_off", "size": 24 },
            { "id": "ignore-icon",   "icon": "ignore",        "size": 24 }
          ],
          "right": [
            { "id": "details-btn", "type": "default", "icon": "drop",           "label": "Details" },
            { "id": "accept-btn",  "type": "accept",  "icon": "success_button", "label": "Accept"  }
          ]
        }
      ]
    },
    "card02": {
      "height": 112,
      "layout": "column",
      "justifyContent": "space-between",
      "rows": [
        {
          "type": "text",
          "segments": [
            { "text": "Greaphing designing", "style": "deleted" },
            { "text": "Graphic design", "style": "inserted" },
            { "text": " is a strong suit of mine.", "style": "sentence" }
          ]
        },
        {
          "type": "actions",
          "left": [
            { "id": "status-label", "type": "status", "icon": "success_status", "label": "Suggestion accepted" }
          ],
          "right": [
            { "id": "undo-btn", "type": "default", "icon": "undo", "label": "Undo" }
          ]
        }
      ]
    },
    "card03": {
      "height": 64,
      "layout": "row",
      "alignItems": "center",
      "left": [
        { "id": "ignored-icon",  "icon": "ignore", "size": 24 },
        { "id": "ignored-label", "type": "ignoredText", "label": "Ignored." }
      ],
      "right": [
        { "id": "undo-btn2",   "type": "default", "icon": "undo",   "label": "Undo"   },
        { "id": "delete-btn",  "type": "default", "icon": "delete", "label": "Delete" }
      ]
    }
  },
