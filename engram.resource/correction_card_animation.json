  "sequence": [
    {
      "step": 1,
      "label": "Initial state",
      "card": "card01",
      "startTime": 0,
      "duration": 900
    },
    {
      "step": 2,
      "label": "Cursor appears and moves to Accept button",
      "card": "card01",
      "startTime": 900,
      "duration": 800,
      "cursor": {
        "action": "move",
        "target": "accept-btn",
        "from": { "offsetX": -80, "offsetY": 40 },
        "to":   { "offsetX": 0,   "offsetY": 0  },
        "easing": "easeInOut"
      }
    },
    {
      "step": 3,
      "label": "Click Accept button",
      "card": "card01",
      "startTime": 1700,
      "duration": 550,
      "cursor": {
        "action": "click",
        "target": "accept-btn",
        "ripple": true
      }
    },
    {
      "step": 4,
      "label": "Cursor disappears, card fades to card02",
      "transition": {
        "from": "card01",
        "to":   "card02",
        "type": "fade",
        "duration": 200
      },
      "startTime": 2250,
      "duration": 200
    },
    {
      "step": 5,
      "label": "Hold card02",
      "card": "card02",
      "startTime": 2450,
      "duration": 1100
    },
    {
      "step": 6,
      "label": "Cursor appears and moves to Undo button",
      "card": "card02",
      "startTime": 3550,
      "duration": 800,
      "cursor": {
        "action": "move",
        "target": "undo-btn",
        "from": { "offsetX": 90, "offsetY": -35 },
        "to":   { "offsetX": 0,  "offsetY": 0   },
        "easing": "easeInOut"
      }
    },
    {
      "step": 7,
      "label": "Click Undo button",
      "card": "card02",
      "startTime": 4350,
      "duration": 550,
      "cursor": {
        "action": "click",
        "target": "undo-btn",
        "ripple": true
      }
    },
    {
      "step": 8,
      "label": "Cursor disappears, card fades back to card01",
      "transition": {
        "from": "card02",
        "to":   "card01",
        "type": "fade",
        "duration": 200
      },
      "startTime": 4900,
      "duration": 200
    },
    {
      "step": 9,
      "label": "Hold card01",
      "card": "card01",
      "startTime": 5100,
      "duration": 1100
    },
    {
      "step": 10,
      "label": "Cursor appears and moves to Ignore icon",
      "card": "card01",
      "startTime": 6200,
      "duration": 800,
      "cursor": {
        "action": "move",
        "target": "ignore-icon",
        "from": { "offsetX": 110, "offsetY": 45 },
        "to":   { "offsetX": 0,   "offsetY": 0  },
        "easing": "easeInOut"
      }
    },
    {
      "step": 11,
      "label": "Click Ignore icon",
      "card": "card01",
      "startTime": 7000,
      "duration": 550,
      "cursor": {
        "action": "click",
        "target": "ignore-icon",
        "ripple": true
      }
    },
    {
      "step": 12,
      "label": "Cursor disappears, card fades to card03",
      "transition": {
        "from": "card01",
        "to":   "card03",
        "type": "fade",
        "duration": 200
      },
      "startTime": 7550,
      "duration": 200
    },
    {
      "step": 13,
      "label": "Hold card03, then loop",
      "card": "card03",
      "startTime": 7750,
      "duration": 2200,
      "next": "loop"
    }
  ],
  "cursor": {
    "width": 20,
    "height": 28,
    "shape": "arrow",
    "fill": "white",
    "stroke": "#222222",
    "strokeWidth": 1.4,
    "svgPath": "M2 2L2 22L7.5 16.5L11 24L13.5 23L10 15.5H17.5L2 2Z",
    "fadeIn":  { "duration": 200, "easing": "linear" },
    "fadeOut": { "duration": 200, "easing": "linear" }
  },
  "transitions": {
    "cardFade": {
      "type": "opacity",
      "outDuration": 200,
      "inDuration": 0,
      "easing": "linear"
    }
  },
  "ripple": {
    "size": 40,
    "color": "rgba(255, 140, 80, 0.28)",
    "expandScale": 2.2,
    "duration": 400,
    "easing": "easeOut"
  }
}
