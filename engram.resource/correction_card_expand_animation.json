  "sequence": [
    {
      "step": 1,
      "label": "Initial collapsed state",
      "card": "collapsed",
      "startTime": 0,
      "duration": 1000
    },
    {
      "step": 2,
      "label": "Cursor appears and moves to Details button",
      "card": "collapsed",
      "startTime": 1000,
      "duration": 850,
      "cursor": {
        "action": "move",
        "target": "details-btn",
        "from": { "offsetX": 80, "offsetY": 40 },
        "to":   { "offsetX": 0,  "offsetY": 0  },
        "easing": "easeInOut"
      }
    },
    {
      "step": 3,
      "label": "Click Details button",
      "card": "collapsed",
      "startTime": 1850,
      "duration": 460,
      "cursor": {
        "action": "click",
        "target": "details-btn",
        "press": {
          "scaleDown": 0.72,
          "scaleUp": 1.08,
          "duration": 280,
          "easing": "easeOut"
        },
        "ripple": {
          "color": "rgba(255,140,80,0.28)",
          "size": 40,
          "expandScale": 2.4,
          "duration": 450
        }
      }
    },
    {
      "step": 4,
      "label": "Cursor disappears, card expands to fit content",
      "transition": {
        "from": "collapsed",
        "to": "expanded",
        "type": "height",
        "heightMethod": "scrollHeight",
        "duration": 400,
        "easing": "cubic-bezier(0.4,0,0.2,1)",
        "contentFadeDelay": 200,
        "contentFadeDuration": 120
      },
      "startTime": 2310,
      "duration": 400
    },
    {
      "step": 5,
      "label": "Hold expanded card",
      "card": "expanded",
      "startTime": 2710,
      "duration": 2400
    },
    {
      "step": 6,
      "label": "Cursor appears and moves to Close button",
      "card": "expanded",
      "startTime": 5110,
      "duration": 850,
      "cursor": {
        "action": "move",
        "target": "close-btn",
        "from": { "offsetX": 80, "offsetY": -40 },
        "to":   { "offsetX": 0,  "offsetY": 0   },
        "easing": "easeInOut"
      }
    },
    {
      "step": 7,
      "label": "Click Close button",
      "card": "expanded",
      "startTime": 5960,
      "duration": 460,
      "cursor": {
        "action": "click",
        "target": "close-btn",
        "press": {
          "scaleDown": 0.72,
          "scaleUp": 1.08,
          "duration": 280,
          "easing": "easeOut"
        },
        "ripple": {
          "color": "rgba(255,140,80,0.28)",
          "size": 40,
          "expandScale": 2.4,
          "duration": 450
        }
      }
    },
    {
      "step": 8,
      "label": "Card collapses back to 112px",
      "transition": {
        "from": "expanded",
        "to": "collapsed",
        "type": "height",
        "targetHeight": 112,
        "duration": 420,
        "easing": "cubic-bezier(0.4,0,0.2,1)",
        "contentFadeFirst": true
      },
      "startTime": 6420,
      "duration": 420
    },
    {
      "step": 9,
      "label": "Hold collapsed, then loop",
      "card": "collapsed",
      "startTime": 6840,
      "duration": 1400,
      "next": "loop"
    }
  ],
  "cursor": {
    "width": 20,
    "height": 28,
    "svgPath": "M2 2L2 22L7.5 16.5L11 24L13.5 23L10 15.5H17.5L2 2Z",
    "fill": "white",
    "stroke": "#222222",
    "strokeWidth": 1.4,
    "transformOrigin": "4px 4px",
    "fadeIn":  { "duration": 200, "easing": "linear" },
    "fadeOut": { "duration": 200, "easing": "linear" },
    "clickAnimation": {
      "keyframes": [
        { "offset": 0,    "scale": 1    },
        { "offset": 0.35, "scale": 0.72 },
        { "offset": 0.70, "scale": 1.08 },
        { "offset": 1,    "scale": 1    }
      ],
      "duration": 280,
      "easing": "ease-out"
    }
  }
}
