{
  "meta": {
    "name": "Correction Card Expand Animation",
    "version": "1.0.0",
    "description": "Two-state correction card animation: collapsed → expanded (Details) → collapsed (Close)",
    "totalDuration": 7010,
    "loop": true
  },
  "design": {
    "card": {
      "width": 492,
      "borderRadius": 8,
      "border": "1px solid #E5E5E5",
      "background": "#FFFFFF",
      "padding": 20,
      "fontFamily": "Pretendard",
      "heightCollapsed": 112,
      "heightExpanded": "auto (measured from scrollHeight)"
    },
    "typography": {
      "sentence":      { "fontSize": 16, "lineHeight": 24, "color": "#1A1A1A" },
      "deleted":       { "fontSize": 16, "lineHeight": 24, "color": "#C13F3F", "textDecoration": "line-through" },
      "inserted":      { "fontSize": 16, "lineHeight": 24, "color": "#FF8C50" },
      "sectionLabel":  { "fontSize": 13, "lineHeight": 18, "color": "#1A1A1A", "fontWeight": 600 },
      "exampleLabel":  { "fontSize": 13, "lineHeight": 18, "color": "#1A1A1A", "fontWeight": 600 },
      "exampleItalic": { "fontSize": 14, "lineHeight": 20, "color": "#888888", "fontStyle": "italic" },
      "examplePlain":  { "fontSize": 14, "lineHeight": 20, "color": "#1A1A1A" },
      "bottomAction":  { "fontSize": 14, "lineHeight": 14, "color": "#888888" },
      "buttonLabel":   { "fontSize": 14, "lineHeight": 14 }
    },
    "buttons": {
      "width": 96,
      "height": 36,
      "borderRadius": 6,
      "iconSize": 24,
      "gap": 4,
      "default": {
        "background": "#FFFFFF",
        "border": "1px solid #D0D0D0",
        "color": "#888888"
      },
      "accept": {
        "background": "#FF8C50",
        "border": "none",
        "color": "#FFFFFF"
      },
      "acceptOutline": {
        "background": "#FFFFFF",
        "border": "1px solid #FF8C50",
        "color": "#FF8C50"
      }
    },
    "spacing": {
      "cardPadding": 20,
      "sectionTopPadding": "20px 20px 0 20px",
      "collapsedActionsPadding": "12px 20px 20px 20px",
      "sectionOtherPadding": "16px 20px 0 20px",
      "exampleBoxMargin": "20px 20px 0 20px",
      "exampleBoxPadding": 16,
      "bottomBarPadding": "12px 20px 20px 20px",
      "bottomBarMarginTop": 16,
      "dividerMargin": "0 20px",
      "btnRowOtherPadding": "12px 0 0 0",
      "btnRowTopPadding": "12px 0 16px 0"
    },
    "colors": {
      "accent": "#FF8C50",
      "deleted": "#C13F3F",
      "muted": "#888888",
      "border": "#E5E5E5",
      "buttonBorder": "#D0D0D0",
      "iconFill": "#555555",
      "iconMuted": "rgba(31,26,23,0.36)",
      "iconMutedMed": "rgba(31,26,23,0.6)"
    }
  },
  "cards": {
    "collapsed": {
      "height": 112,
      "sections": [
        {
          "type": "textRow",
          "padding": "20px 20px 0 20px",
          "segments": [
            { "text": "Greaphing designing", "style": "deleted" },
            { "text": "Graphic design",      "style": "inserted" },
            { "text": " is a strong suit of mine.", "style": "sentence" }
          ]
        },
        {
          "type": "actionRow",
          "padding": "12px 20px 20px 20px",
          "left": [
            { "id": "bookmark-icon", "icon": "bookmark" },
            { "id": "ignore-icon",   "icon": "ignore" }
          ],
          "right": [
            { "id": "details-btn",    "buttonType": "default",  "icon": "drop",         "label": "Details" },
            { "id": "main-accept-btn","buttonType": "accept",   "icon": "successWhite", "label": "Accept",  "marginLeft": 8 }
          ]
        }
      ]
    },
    "expanded": {
      "height": "auto",
      "sections": [
        {
          "type": "textRow",
          "showSectionLabel": true,
          "sectionLabel": "Top Pick",
          "padding": "20px 20px 0 20px",
          "segments": [
            { "text": "Greaphing designing", "style": "deleted" },
            { "text": "Graphic design",      "style": "inserted" },
            { "text": " is a strong suit of mine.", "style": "sentence" }
          ],
          "actionRight": [
            { "id": "top-accept-btn", "buttonType": "accept", "icon": "successWhite", "label": "Accept" }
          ]
        },
        {
          "type": "divider",
          "margin": "0 20px"
        },
        {
          "type": "textRow",
          "showSectionLabel": true,
          "sectionLabel": "Other Option",
          "padding": "16px 20px 0 20px",
          "segments": [
            { "text": "Graphic",     "style": "inserted" },
            { "text": "designing is a strong suit of mine.", "style": "sentence" }
          ],
          "actionRight": [
            { "id": "other-accept-btn", "buttonType": "acceptOutline", "icon": "successOrange", "label": "Accept" }
          ]
        },
        {
          "type": "exampleBox",
          "margin": "20px 20px 0 20px",
          "padding": 16,
          "border": "1px solid #E5E5E5",
          "borderRadius": 8,
          "items": [
            { "label": "Example Sentence", "text": "I am good at graphic design.",       "style": "italic" },
            { "label": "Similar Sentence",  "text": "I have a talent in graphic design",  "style": "plain" }
          ]
        },
        {
          "type": "bottomBar",
          "padding": "12px 20px 20px 20px",
          "marginTop": 16,
          "borderTop": "1px solid #E5E5E5",
          "left": [
            { "id": "ignore-action",   "icon": "ignore",   "label": "Ignore" },
            { "id": "feedback-action", "icon": "feedback", "label": "Feedback" }
          ],
          "right": [
            { "id": "close-btn", "buttonType": "default", "icon": "chevronUp", "label": "Close" }
          ]
        }
      ]
    }
  },
